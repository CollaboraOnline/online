msgstr "Colonne 1, Colonne 2,... la liste des numéros de colonnes à renvoyer."

#. 78gQu
#: sc/inc/scfuncs.hrc:4267
msgctxt "SC_OPCODE_CHOOSEROWS"
msgid "Returns the specified rows from an array."
msgstr "Renvoie les lignes spécifiées d'une matrice."

#. JAg4y
#: sc/inc/scfuncs.hrc:4268
msgctxt "SC_OPCODE_CHOOSEROWS"
msgid "Array"
msgstr "Matrice"

#. GFWtk
#: sc/inc/scfuncs.hrc:4269
msgctxt "SC_OPCODE_CHOOSEROWS"
msgid "The array containing the rows to be returned in the new array."
msgstr "La matrice contenant les lignes à renvoyer dans la nouvelle matrice."

#. PDBbE
#: sc/inc/scfuncs.hrc:4270
msgctxt "SC_OPCODE_CHOOSEROWS"
msgid "Row "
msgstr "Ligne "

#. dXjgB
#: sc/inc/scfuncs.hrc:4271
msgctxt "SC_OPCODE_CHOOSEROWS"
msgid "Row 1, Row 2,... The list of row numbers to be returned."
msgstr "Ligne 1, Ligne 2,... la liste des numéros de ligne à renvoyer."

#. 4uTLx
#: sc/inc/scfuncs.hrc:4277
msgctxt "SC_OPCODE_DROP"
msgid ""
"Excludes a specified number of contiguous rows or columns from the start or "
"end of an array."
msgstr ""
"Exclut un nombre spécifié de lignes ou de colonnes contiguës du début ou de "
"la fin d'une matrice."

#. W6FYc
#: sc/inc/scfuncs.hrc:4278
msgctxt "SC_OPCODE_DROP"
msgid "Array"
msgstr "Matrice"

#. zEu4G
#: sc/inc/scfuncs.hrc:4279
msgctxt "SC_OPCODE_DROP"
msgid "The array from which to drop rows or columns."
msgstr "La matrice à partir de laquelle supprimer des lignes ou des colonnes."

#. BFPt4
#: sc/inc/scfuncs.hrc:4280
msgctxt "SC_OPCODE_DROP"
msgid "Rows"
msgstr "Lignes"

#. yyjnc
#: sc/inc/scfuncs.hrc:4281
msgctxt "SC_OPCODE_DROP"
msgid ""
"The number of rows to drop. A negative value drops from the end of the array."
msgstr ""
"Nombre de lignes à supprimer. Une valeur négative supprime la fin d'une "
"matrice."

#. 6sAoA
#: sc/inc/scfuncs.hrc:4282
msgctxt "SC_OPCODE_DROP"
msgid "Columns"
msgstr ""

#. cAxPB
#: sc/inc/scfuncs.hrc:4283
msgctxt "SC_OPCODE_DROP"
msgid ""
"The number of columns to drop. A negative value drops from the end of the "
"array."
msgstr ""
"Nombre de colonnes à supprimer. Une valeur négative supprime la fin de la "
"matrice."

#. cXvVY
#: sc/inc/scfuncs.hrc:4289
msgctxt "SC_OPCODE_EXPAND"
msgid "Expands or pads an array to specified row and column dimensions."
msgstr ""
"Étend ou complète une matrice selon les dimensions de ligne et de colonne "
"spécifiées."

#. kuERH
#: sc/inc/scfuncs.hrc:4290
msgctxt "SC_OPCODE_EXPAND"
msgid "Array"
msgstr "Matrice"

#. E9YDC
#: sc/inc/scfuncs.hrc:4291
msgctxt "SC_OPCODE_EXPAND"
msgid "The array to expand."
msgstr "La matrice à étendre."

#. EaNgG
#: sc/inc/scfuncs.hrc:4292
msgctxt "SC_OPCODE_EXPAND"
msgid "Rows"
msgstr "Lignes"

#. QzQiB
#: sc/inc/scfuncs.hrc:4293
msgctxt "SC_OPCODE_EXPAND"
msgid ""
"The number of rows in the expanded array. If missing, rows will not be "
"expanded."
msgstr ""
"Le nombre de lignes dans la matrice développée. S'il est manquant, les "
"lignes ne seront pas étendues."

#. qjcxB
#: sc/inc/scfuncs.hrc:4294
msgctxt "SC_OPCODE_EXPAND"
msgid "Columns"
msgstr ""

#. EVAXE
#: sc/inc/scfuncs.hrc:4295
msgctxt "SC_OPCODE_EXPAND"
msgid ""
"The number of columns in the expanded array. If missing, columns will not be "
"expanded."
msgstr ""
"Nombre de colonnes dans la matrice développée. Si ce nombre est manquant, "
"les colonnes ne seront pas étendues."

#. QPyBK
#: sc/inc/scfuncs.hrc:4296
msgctxt "SC_OPCODE_EXPAND"
msgid "Pad with"
msgstr "Étendre avec"

#. kHatA
#: sc/inc/scfuncs.hrc:4297
msgctxt "SC_OPCODE_EXPAND"
msgid "The value with which to pad. The default is #N/A."
msgstr "La valeur avec laquelle compléter. La valeur par défaut est #N/D."

#. m7qUf
#: sc/inc/scfuncs.hrc:4303
msgctxt "SC_OPCODE_HSTACK"
msgid "Appends arrays horizontally to create a larger array."
msgstr ""

#. LnAFg
#: sc/inc/scfuncs.hrc:4304 sc/inc/scfuncs.hrc:4306
msgctxt "SC_OPCODE_HSTACK"
msgid "Array"
msgstr "Matrice"

#. uHbHC
#: sc/inc/scfuncs.hrc:4305
msgctxt "SC_OPCODE_HSTACK"
msgid "The first array to append."
msgstr "La première matrice à ajouter."

#. QRA57
#: sc/inc/scfuncs.hrc:4307
msgctxt "SC_OPCODE_HSTACK"
msgid ""
"Array 1, Array 2,... The following arrays to append. If an array has fewer "
"rows, #N/A error will be returned in the additional rows."
msgstr ""
"Matrice 1, matrice 2,... Les matrices suivantes à ajouter. Si une matrice "
"comporte moins de lignes, l'erreur #N/D sera renvoyée dans les lignes "
"supplémentaires."

#. 7zS24
#: sc/inc/scfuncs.hrc:4313
msgctxt "SC_OPCODE_VSTACK"
msgid "Appends arrays vertically to create a larger array."
msgstr ""

#. rhVRC
#: sc/inc/scfuncs.hrc:4314 sc/inc/scfuncs.hrc:4316
msgctxt "SC_OPCODE_VSTACK"
msgid "Array"
msgstr "Matrice"

#. tGHH9
#: sc/inc/scfuncs.hrc:4315
msgctxt "SC_OPCODE_VSTACK"
msgid "The first array to append."
msgstr "La première matrice à ajouter."

#. Kb6Xc
#: sc/inc/scfuncs.hrc:4317
msgctxt "SC_OPCODE_VSTACK"
msgid ""
"Array 1, Array 2,... The following arrays to append. If an array has fewer "
"columns, #N/A error will be returned in the additional columns."
msgstr ""
"Matrice 1, matrice 2,... Les matrices suivantes à ajouter. Si une matrice "
"comporte moins de lignes, l'erreur #N/D sera renvoyée dans les lignes "
"supplémentaires."

#. JnsYT
#: sc/inc/scfuncs.hrc:4323
msgctxt "SC_OPCODE_TAKE"
msgid ""
"Returns a specified number of contiguous rows or columns from the start or "
"end of an array."
msgstr ""
"Renvoie un nombre spécifié de lignes ou de colonnes contiguës à partir du "
"début ou de la fin d'une matrice."

#. dFLFb
#: sc/inc/scfuncs.hrc:4324
msgctxt "SC_OPCODE_TAKE"
msgid "Array"
msgstr "Matrice"

#. ycFef
#: sc/inc/scfuncs.hrc:4325
msgctxt "SC_OPCODE_TAKE"
msgid "The array from which to take rows or columns."
msgstr "La matrice à partir de laquelle prendre les lignes et les colonnes."

#. DzBCL
#: sc/inc/scfuncs.hrc:4326
msgctxt "SC_OPCODE_TAKE"
msgid "Rows"
msgstr "Lignes"

#. KBPBn
#: sc/inc/scfuncs.hrc:4327
msgctxt "SC_OPCODE_TAKE"
msgid ""
"The number of rows to take. A negative value takes from the end of the array."
msgstr ""
"Le nombre de lignes à prendre. Une valeur négative prend à partir de la fin "
"de la matrice."

#. HJQKW
#: sc/inc/scfuncs.hrc:4328
msgctxt "SC_OPCODE_TAKE"
msgid "Columns"
msgstr ""

#. ZexcG
#: sc/inc/scfuncs.hrc:4329
msgctxt "SC_OPCODE_TAKE"
msgid ""
"The number of columns to take. A negative value takes from the end of the "
"array."
msgstr ""
"Le nombre de colonnes à prendre. Une valeur négative prend à partir de la "
"fin de la matrice."

#. GwyMB
#: sc/inc/scfuncs.hrc:4335
msgctxt "SC_OPCODE_TEXTAFTER"
msgid "Returns the text that occurs after a given substring or delimiter."
msgstr ""
"Renvoie le texte qui apparaît après une sous-chaîne ou un délimiteur donné."

#. cicY2
#: sc/inc/scfuncs.hrc:4336
msgctxt "SC_OPCODE_TEXTAFTER"
msgid "Text"
msgstr "Texte"

#. 3WLYF
#: sc/inc/scfuncs.hrc:4337
msgctxt "SC_OPCODE_TEXTAFTER"
msgid "The original text."
msgstr "Le texte original."

#. z4pDr
#: sc/inc/scfuncs.hrc:4338
msgctxt "SC_OPCODE_TEXTAFTER"
msgid "Delimiter"
msgstr "Séparateur"

#. YEbwu
#: sc/inc/scfuncs.hrc:4339
msgctxt "SC_OPCODE_TEXTAFTER"
msgid "The delimiter. Multiple delimiters can be supplied."
msgstr "Le délimiteur. Plusieurs délimiteurs peuvent être fournis."

#. HPDvF
#: sc/inc/scfuncs.hrc:4340
msgctxt "SC_OPCODE_TEXTAFTER"
msgid "Instance Number"
msgstr "Numéro d'instance"

#. DmVZL
#: sc/inc/scfuncs.hrc:4341
msgctxt "SC_OPCODE_TEXTAFTER"
msgid ""
"The instance of the delimiter after which to extract text. The default is 1. "
"A negative number starts searching from the end."
msgstr ""
"Instance du délimiteur à partir duquel extraire le texte. La valeur par "
"défaut est 1. Un nombre négatif permet de lancer la recherche depuis la fin."

#. fpoGj
#: sc/inc/scfuncs.hrc:4342
msgctxt "SC_OPCODE_TEXTAFTER"
msgid "Match Mode"
msgstr "Mode Correspondre"

#. iSfJi
#: sc/inc/scfuncs.hrc:4343
msgctxt "SC_OPCODE_TEXTAFTER"
msgid "Set to 1 to perform a case-insensitive match. The default is 0."
msgstr ""
"Définissez la valeur sur 1 pour effectuer une correspondance insensible à la "
"casse. La valeur par défaut est 0."

#. nAF2s
#: sc/inc/scfuncs.hrc:4344
msgctxt "SC_OPCODE_TEXTAFTER"
msgid "Match End"
msgstr "Correspondre à la fin"

#. W2DGj
#: sc/inc/scfuncs.hrc:4345
msgctxt "SC_OPCODE_TEXTAFTER"
msgid "Set to 1 to treat the end of text as a delimiter. The default is 0."
msgstr ""
"Définissez la valeur sur 1 pour traiter la fin du texte comme un délimiteur. "
"La valeur par défaut est 0."

#. PG6qj
#: sc/inc/scfuncs.hrc:4346
msgctxt "SC_OPCODE_TEXTAFTER"
msgid "If Not Found"
msgstr "Si Non trouvé"

#. vfgZc
#: sc/inc/scfuncs.hrc:4347
msgctxt "SC_OPCODE_TEXTAFTER"
msgid "The value returned if no match is found. The default is #N/A."
msgstr ""
"Valeur renvoyée si aucune correspondance n'est trouvée. La valeur par défaut "
"est #N/D."

#. f88EE
#: sc/inc/scfuncs.hrc:4353
msgctxt "SC_OPCODE_TEXTBEFORE"
msgid "Returns the text that occurs before a given substring or delimiter."
msgstr ""
"Renvoie le texte qui apparaît avant une sous-chaîne ou un délimiteur donné."

#. NNriC
#: sc/inc/scfuncs.hrc:4354
msgctxt "SC_OPCODE_TEXTBEFORE"
msgid "Text"
msgstr "Texte"

#. HsEG8
#: sc/inc/scfuncs.hrc:4355
msgctxt "SC_OPCODE_TEXTBEFORE"
msgid "The original text."
msgstr "Le texte original."

#. E4a5z
#: sc/inc/scfuncs.hrc:4356
msgctxt "SC_OPCODE_TEXTBEFORE"
msgid "Delimiter"
msgstr "Séparateur"

#. qDFZy
#: sc/inc/scfuncs.hrc:4357
msgctxt "SC_OPCODE_TEXTBEFORE"
msgid "The delimiter. Multiple delimiters can be supplied."
msgstr "Le délimiteur. Plusieurs délimiteurs peuvent être fournis."

#. gNHAi
#: sc/inc/scfuncs.hrc:4358
msgctxt "SC_OPCODE_TEXTBEFORE"
msgid "Instance Number"
msgstr "Numéro d'instance"

#. sD4zC
#: sc/inc/scfuncs.hrc:4359
msgctxt "SC_OPCODE_TEXTBEFORE"
msgid ""
"The instance of the delimiter before which to extract text. The default is "
"1. A negative number starts searching from the end."
msgstr ""
"Instance du délimiteur avant lequel extraire le texte. La valeur par défaut "
"est 1. Un nombre négatif lance la recherche depuis la fin."

#. Adzeh
#: sc/inc/scfuncs.hrc:4360
msgctxt "SC_OPCODE_TEXTBEFORE"
msgid "Match Mode"
msgstr "Mode Correspondre"

#. Pi2Ti
#: sc/inc/scfuncs.hrc:4361
msgctxt "SC_OPCODE_TEXTBEFORE"
msgid "Set to 1 to perform a case-insensitive match. The default is 0."
msgstr ""
"Définissez la valeur sur 1 pour effectuer une correspondance insensible à la "
"casse. La valeur par défaut est 0."

#. sACA2
#: sc/inc/scfuncs.hrc:4362
msgctxt "SC_OPCODE_TEXTBEFORE"
msgid "Match End"
msgstr "Correspondre à la fin"

#. UxpD6
#: sc/inc/scfuncs.hrc:4363
msgctxt "SC_OPCODE_TEXTBEFORE"
msgid "Set to 1 to treat the end of text as a delimiter. The default is 0."
msgstr ""
"Définissez la valeur sur 1 pour traiter la fin du texte comme un délimiteur. "
"La valeur par défaut est 0."

#. aCnZX
#: sc/inc/scfuncs.hrc:4364
msgctxt "SC_OPCODE_TEXTBEFORE"
msgid "If Not Found"
msgstr "Si Non trouvé"

#. xCZYH
#: sc/inc/scfuncs.hrc:4365
msgctxt "SC_OPCODE_TEXTBEFORE"
msgid "The value returned if no match is found. The default is #N/A."
msgstr ""
"Valeur renvoyée si aucune correspondance n'est trouvée. La valeur par défaut "
"est #N/D."

#. wdZTd
#: sc/inc/scfuncs.hrc:4371
msgctxt "SC_OPCODE_TEXTSPLIT"
msgid "Splits text by a given delimiter to an array of multiple cells."
msgstr ""
"Divise le texte par un délimiteur donné en une matrice de plusieurs cellules."

#. DH7h4
#: sc/inc/scfuncs.hrc:4372
msgctxt "SC_OPCODE_TEXTSPLIT"
msgid "Text"
msgstr "Texte"

#. dqSdF
#: sc/inc/scfuncs.hrc:4373
msgctxt "SC_OPCODE_TEXTSPLIT"
msgid "The text to split."
msgstr "Le texte à diviser."

#. pdpxt
#: sc/inc/scfuncs.hrc:4374
msgctxt "SC_OPCODE_TEXTSPLIT"
msgid "Column Delimiter"
msgstr "Délimiteur de colonne"

#. nfMAr
#: sc/inc/scfuncs.hrc:4375
msgctxt "SC_OPCODE_TEXTSPLIT"
msgid "The text to delimit the columns. Multiple delimiters can be supplied."
msgstr ""
"Texte délimitant les colonnes. Plusieurs délimiteurs peuvent être fournis."

#. qZGq2
#: sc/inc/scfuncs.hrc:4376
msgctxt "SC_OPCODE_TEXTSPLIT"
msgid "Row Delimiter"
msgstr "Délimiteur de ligne"

#. dPnbc
#: sc/inc/scfuncs.hrc:4377
msgctxt "SC_OPCODE_TEXTSPLIT"
msgid "The text to delimit the rows. Multiple delimiters can be supplied."
msgstr ""
"Texte délimitant les lignes. Plusieurs délimiteurs peuvent être fournis."

#. jD3sa
#: sc/inc/scfuncs.hrc:4378
msgctxt "SC_OPCODE_TEXTSPLIT"
msgid "Ignore Empty"
msgstr "Ignorer si vide"

#. 6LwdP
#: sc/inc/scfuncs.hrc:4379
msgctxt "SC_OPCODE_TEXTSPLIT"
msgid ""
"Set to TRUE to ignore consecutive delimiters otherwise it creates an empty "
"cell. The default is FALSE."
msgstr ""
"Définissez cette option sur VRAI pour ignorer les délimiteurs consécutifs. "
"Sinon, une cellule vide est créée. La valeur par défaut est FAUX."

#. kkAYp
#: sc/inc/scfuncs.hrc:4380
msgctxt "SC_OPCODE_TEXTSPLIT"
msgid "Match mode"
msgstr "Mode Correspondre"

#. iX8cx
#: sc/inc/scfuncs.hrc:4381
msgctxt "SC_OPCODE_TEXTSPLIT"
msgid "Set to 1 to perform a case-insensitive match. The default is 0."
msgstr ""
"Définissez la valeur sur 1 pour effectuer une correspondance insensible à la "
"casse. La valeur par défaut est 0."

#. vXECz
#: sc/inc/scfuncs.hrc:4382
msgctxt "SC_OPCODE_TEXTSPLIT"
msgid "Pad with"
msgstr "Étendre avec"

#. h4db2
#: sc/inc/scfuncs.hrc:4383
msgctxt "SC_OPCODE_TEXTSPLIT"
msgid "The value with which to pad. The default is #N/A."
msgstr "La valeur avec laquelle compléter. La valeur par défaut est #N/D."

#. DdFFE
#: sc/inc/scfuncs.hrc:4389
msgctxt "SC_OPCODE_TOCOL"
msgid "Transforms an array into a single column."
msgstr ""

#. UAzNC
#: sc/inc/scfuncs.hrc:4390
msgctxt "SC_OPCODE_TOCOL"
msgid "Array"
msgstr "Matrice"

#. CHojs
#: sc/inc/scfuncs.hrc:4391
msgctxt "SC_OPCODE_TOCOL"
msgid "The range or array to return as a single column."
msgstr "La plage ou la matrice à renvoyer sous forme d'une seule colonne."

#. uACXu
#: sc/inc/scfuncs.hrc:4392
msgctxt "SC_OPCODE_TOCOL"
msgid "Ignore"
msgstr "Ignorer"

#. b7EQW
#: sc/inc/scfuncs.hrc:4393
msgctxt "SC_OPCODE_TOCOL"
msgid ""
"Whether to ignore certain types of values. 0 or omitted - keep all values "
"(default). 1 - ignore blank cells. 2 - ignore cells with error. 3 - ignore "
"blanks cells and cells with error."
msgstr ""
"S'il faut ignorer certains types de valeurs. 0 ou omis - conserver toutes "
"les valeurs (par défaut). 1 - ignorer les cellules vides. 2 - ignorer les "
"cellules avec erreur. 3 - ignorer les cellules vides et les cellules avec "
"erreur."

#. qNLAi
#: sc/inc/scfuncs.hrc:4394
msgctxt "SC_OPCODE_TOCOL"
msgid "Scan by column"
msgstr "Numériser par colonne"

#. bcArN
#: sc/inc/scfuncs.hrc:4395
msgctxt "SC_OPCODE_TOCOL"
msgid ""
"Scan the array by column. FALSE or omitted (default) - the array is scanned "
"by row. TRUE - the array is scanned by column."
msgstr ""
"Examine la matrice par colonne. FAUX ou omis (par défaut) - la matrice est "
"examinée par ligne. VRAI - la matrice est examinée par colonne."

#. PGyxj
#: sc/inc/scfuncs.hrc:4401
msgctxt "SC_OPCODE_TOROW"
msgid "transforms an array into a single row."
msgstr "transforme une matrice en une simple ligne."

#. W9bWe
#: sc/inc/scfuncs.hrc:4402
msgctxt "SC_OPCODE_TOROW"
msgid "Array"
msgstr "Matrice"

#. 5MEvT
#: sc/inc/scfuncs.hrc:4403
msgctxt "SC_OPCODE_TOROW"
msgid "The range or array to return as a single row."
msgstr "La plage ou la matrice à renvoyer sous forme d'une seule ligne."

#. AqqBC
#: sc/inc/scfuncs.hrc:4404
msgctxt "SC_OPCODE_TOROW"
msgid "Ignore"
msgstr "Ignorer"

#. wcpQF
#: sc/inc/scfuncs.hrc:4405
msgctxt "SC_OPCODE_TOROW"
msgid ""
"Whether to ignore certain types of values. 0 or omitted - keep all values "
"(default). 1 - ignore blank cells. 2 - ignore cells with error. 3 - ignore "
"blanks cells and cells with error."
msgstr ""
"S'il faut ignorer certains types de valeurs. 0 ou omis - conserver toutes "
"les valeurs (par défaut). 1 - ignorer les cellules vides. 2 - ignorer les "
"cellules avec erreur. 3 - ignorer les cellules vides et les cellules avec "
"erreur."

#. E4XDf
#: sc/inc/scfuncs.hrc:4406
msgctxt "SC_OPCODE_TOROW"
msgid "Scan by column"
msgstr "Examiner par colonne"

#. 5bZRy
#: sc/inc/scfuncs.hrc:4407
msgctxt "SC_OPCODE_TOROW"
msgid ""
"Scan the array by column. FALSE or omitted (default) - the array is scanned "
"by row. TRUE - the array is scanned by column."
msgstr ""
"Examine la matrice par colonne. FAUX ou omis (par défaut) - la matrice est "
"examinée par ligne. VRAI - la matrice est examinée par colonne."

#. oBDEA
#: sc/inc/scfuncs.hrc:4437
msgctxt "SC_OPCODE_WRAPCOLS"
msgid ""
"Wraps the provided row or column of values by columns after a specified "
"number of elements to form a new array."
msgstr ""
"Adapte les valeurs fournies à la ligne et la colonne par colonnes après un "
"nombre d'éléments spécifié afin de former une nouvelle matrice."

#. fC6RK
#: sc/inc/scfuncs.hrc:4438
msgctxt "SC_OPCODE_WRAPCOLS"
msgid "Range"
msgstr "Plage"

#. nfZyj
#: sc/inc/scfuncs.hrc:4439
msgctxt "SC_OPCODE_WRAPCOLS"
msgid "the range to wrap."
msgstr "la plage à adapter."

#. GE3HQ
#: sc/inc/scfuncs.hrc:4440
msgctxt "SC_OPCODE_WRAPCOLS"
msgid "Wrap count"
msgstr "Nombre d'adaptations"

#. FWsCt
#: sc/inc/scfuncs.hrc:4441
msgctxt "SC_OPCODE_WRAPCOLS"
msgid "The maximum number of values for each column."
msgstr "Le nombre maximum de valeurs pour chaque colonne."

#. zkjFB
#: sc/inc/scfuncs.hrc:4442
msgctxt "SC_OPCODE_WRAPCOLS"
msgid "Pad with"
msgstr "Étendre avec"

