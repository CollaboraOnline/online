msgstr ""
"Adapte les valeurs fournies à la ligne et la colonne par lignes après un "
"nombre d'éléments spécifié afin de former une nouvelle matrice."

#. 7esii
#: sc/inc/scfuncs.hrc:4450
msgctxt "SC_OPCODE_WRAPROWS"
msgid "Range"
msgstr "Plage"

#. FLJwx
#: sc/inc/scfuncs.hrc:4451
msgctxt "SC_OPCODE_WRAPROWS"
msgid "the range to wrap."
msgstr "la plage à adapter."

#. aLHUi
#: sc/inc/scfuncs.hrc:4452
msgctxt "SC_OPCODE_WRAPROWS"
msgid "Wrap count"
msgstr "Nombre d'adaptations"

#. 3CEsK
#: sc/inc/scfuncs.hrc:4453
msgctxt "SC_OPCODE_WRAPROWS"
msgid "The maximum number of values for each row."
msgstr "Le nombre maximum de valeurs pour chaque ligne."

