msgstr ""
"Обертає наданий рядок або стовпець значень по рядках після вказаної "
"кількості елементів, утворюючи новий масив."

#. 7esii
#: sc/inc/scfuncs.hrc:4450
msgctxt "SC_OPCODE_WRAPROWS"
msgid "Range"
msgstr "Діапазон"

#. FLJwx
#: sc/inc/scfuncs.hrc:4451
msgctxt "SC_OPCODE_WRAPROWS"
msgid "the range to wrap."
msgstr "діапазон для обертання."

#. aLHUi
#: sc/inc/scfuncs.hrc:4452
msgctxt "SC_OPCODE_WRAPROWS"
msgid "Wrap count"
msgstr "Кількість обертів"

#. 3CEsK
#: sc/inc/scfuncs.hrc:4453
msgctxt "SC_OPCODE_WRAPROWS"
msgid "The maximum number of values for each row."
msgstr "Максимальна кількість значень для кожного рядка."

#. iTCWg
#: sc/inc/scfuncs.hrc:4454
msgctxt "SC_OPCODE_WRAPROWS"
msgid "Pad with"
msgstr "Вкласти"

