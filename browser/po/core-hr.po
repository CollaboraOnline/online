msgctxt "SC_OPCODE_TOROW"
msgid "Scan by column"
msgstr "Pretraži po stupcima"

#. 5bZRy
#: sc/inc/scfuncs.hrc:4407
msgctxt "SC_OPCODE_TOROW"
msgid ""
"Scan the array by column. FALSE or omitted (default) - the array is scanned "
"by row. TRUE - the array is scanned by column."
msgstr ""
"Pretraži niz po stupcima. FALSE ili izostavljeno (standardno) – niz se "
"pretražuje po redcima. TRUE – niz se pretražuje po stupcima."

#. oBDEA
#: sc/inc/scfuncs.hrc:4437
msgctxt "SC_OPCODE_WRAPCOLS"
msgid ""
"Wraps the provided row or column of values by columns after a specified "
"number of elements to form a new array."
msgstr ""
"Prelama zadani redak ili stupac s vrijednostima po stupcima nakon određenog "
"broja elemenata kako bi stvorio novi niz."

#. fC6RK
#: sc/inc/scfuncs.hrc:4438
msgctxt "SC_OPCODE_WRAPCOLS"
msgid "Range"
msgstr "Raspon"

#. nfZyj
#: sc/inc/scfuncs.hrc:4439
msgctxt "SC_OPCODE_WRAPCOLS"
msgid "the range to wrap."
msgstr "raspon za prelamanje."

#. GE3HQ
#: sc/inc/scfuncs.hrc:4440
msgctxt "SC_OPCODE_WRAPCOLS"
msgid "Wrap count"
msgstr "Broj za prelamanje stupca"

#. FWsCt
#: sc/inc/scfuncs.hrc:4441
msgctxt "SC_OPCODE_WRAPCOLS"
msgid "The maximum number of values for each column."
msgstr "Maksimalan broj vrijednosti za svaki stupac."

#. zkjFB
#: sc/inc/scfuncs.hrc:4442
msgctxt "SC_OPCODE_WRAPCOLS"
msgid "Pad with"
msgstr "Popuni prazna polja sa"

#. knbjc
#: sc/inc/scfuncs.hrc:4443
msgctxt "SC_OPCODE_WRAPCOLS"
msgid "The value with which to pad. The default is #N/A."
msgstr "Vrijednost za popunjavanje praznih polja. Standardno je #N/A."

#. BDA7q
#: sc/inc/scfuncs.hrc:4449
msgctxt "SC_OPCODE_WRAPROWS"
msgid ""
"Wraps the provided row or column of values by rows after a specified number "
"of elements to form a new array."
msgstr ""
"Prelama zadani redak ili stupac s vrijednostima po redcima nakon određenog "
"broja elemenata kako bi stvorio novi niz."

#. 7esii
#: sc/inc/scfuncs.hrc:4450
msgctxt "SC_OPCODE_WRAPROWS"
msgid "Range"
msgstr "Raspon"

#. FLJwx
#: sc/inc/scfuncs.hrc:4451
msgctxt "SC_OPCODE_WRAPROWS"
msgid "the range to wrap."
msgstr "aspon za prelamanje."

#. aLHUi
#: sc/inc/scfuncs.hrc:4452
msgctxt "SC_OPCODE_WRAPROWS"
msgid "Wrap count"
msgstr "Broj za prelamanje retka"

#. 3CEsK
#: sc/inc/scfuncs.hrc:4453
msgctxt "SC_OPCODE_WRAPROWS"
msgid "The maximum number of values for each row."
msgstr "Maksimalan broj vrijednosti za svaki redak."

#. iTCWg
#: sc/inc/scfuncs.hrc:4454
msgctxt "SC_OPCODE_WRAPROWS"
msgid "Pad with"
msgstr "Popuni prazna polja sa"

#. e3K5s
#: sc/inc/scfuncs.hrc:4455
msgctxt "SC_OPCODE_WRAPROWS"
msgid "The value with which to pad. The default is #N/A."
msgstr "Vrijednost za popunjavanje praznih polja. Standardno je #N/A."

#. 4af9a
#: sc/uiconfig/scalc/ui/cellprotectionpage.ui:99
msgctxt "cellprotectionpage|label1"
msgid ""
"Cell protection is only effective after the current sheet has been "
"protected. By default all cells in a sheet are protected - to protect "
"individual cells first select all cells and toggle off the \"Protected\" "
"option in the Format Cells dialog."
msgstr ""
"Zaštita ćelija djeluje tek nakon što se trenutačni list zaštiti. Standardno "
"su ćelije na listu zaštićene – za štićenje pojedinačnih ćelija, najprije "
"odaberi sve ćelije i isključi opciju „Zaštićeno“ u dijaloškom okviru "
"formatiranje ćelija."

